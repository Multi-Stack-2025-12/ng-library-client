# Backend API
LIBRARY_URL=http://localhost:8082/api/v1

# Telemetry
OTEL_COLLECTOR_ENDPOINT=http://localhost:4318/v1/traces
TELEMETRY_HTTP_CAPTURE_DETAILS=true
TELEMETRY_HTTP_MAX_ATTRIBUTE_LENGTH=4000
TELEMETRY_HTTP_RESPONSE_BODY_MAX_LENGTH=2000

# IDP / OIDC
IDP_ISSUER=http://localhost:8081/realms/multi-stack
IDP_CLIENT_ID=multi-stack-ng
IDP_REDIRECT_URI=http://localhost:4200/security/auth/callback
IDP_RESPONSE_TYPE=code
IDP_SCOPE=openid profile email offline_access scp-multi-stack-ng
IDP_POST_LOGOUT_REDIRECT_URI=http://localhost:4200
IDP_STRICT_DISCOVERY_DOCUMENT_VALIDATION=false
IDP_SHOW_DEBUG_INFORMATION=true
IDP_REQUIRE_HTTPS=false
