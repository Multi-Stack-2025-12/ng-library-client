ojects/library-catalog/src/lib/infrastructure/providers/integration.provider.ts\",\"../../../projects/library-catalog/src/public-api.ts\",\"../../../projects/library-catalog/src/library-catalog.ts\"],\"sourcesContent\":[\"import { Component } from '@angular/core';\\r\\nimport { RouterLink, RouterLinkActive, RouterOutlet } from '@angular/router';\\r\\nimport { MatCardModule } from '@angular/material/card';\\r\\nimport { MatIconModule } from '@angular/material/icon';\\r\\nimport { MatButtonModule } from '@angular/material/button';\\r\\nimport { MatMenuModule } from '@angular/material/menu';\\r\\n\\r\\n@Component({\\r\\n  selector: 'lib-catalog-shell',\\r\\n  imports: [\\r\\n    RouterOutlet,\\r\\n    RouterLink,\\r\\n    RouterLinkActive,\\r\\n    MatCardModule,\\r\\n    MatIconModule,\\r\\n    MatButtonModule,\\r\\n    MatMenuModule,\\r\\n  ],\\r\\n  templateUrl: './catalog-shell.html',\\r\\n  styleUrl: './catalog-shell.scss',\\r\\n})\\r\\nexport class CatalogShell {}\\r\\n\",\"<mat-card>\\r\\n  <mat-card-header>\\r\\n    <mat-card-title>\\r\\n      <button mat-button disabled class=\\\"title-text-enable\\\">\\r\\n        <mat-icon>menu_book</mat-icon>\\r\\n        Catalog\\r\\n      </button>\\r\\n    </mat-card-title>\\r\\n\\r\\n    <span class=\\\"lib-spacer\\\"></span>\\r\\n\\r\\n    <button mat-icon-button [matMenuTriggerFor]=\\\"menu\\\" aria-label=\\\"Toggle menu\\\">\\r\\n      <mat-icon>more_vert</mat-icon>\\r\\n    </button>\\r\\n    <mat-menu #menu=\\\"matMenu\\\" xPosition=\\\"before\\\">\\r\\n      <a mat-menu-item\\r\\n         data-action=\\\"catalog-shell.nav-literary-genres\\\"\\r\\n         [routerLink]=\\\"['./literary-genres']\\\"\\r\\n         routerLinkActive=\\\"is-active\\\"\\r\\n         #rlaGenres=\\\"routerLinkActive\\\"\\r\\n         [attr.aria-current]=\\\"rlaGenres.isActive ? 'page' : null\\\">\\r\\n        <mat-icon>category</mat-icon>\\r\\n        <span>Literary Genres</span>\\r\\n      </a>\\r\\n      <a mat-menu-item\\r\\n         data-action=\\\"catalog-shell.nav-publishers\\\"\\r\\n         [routerLink]=\\\"['./publishers']\\\"\\r\\n         routerLinkActive=\\\"is-active\\\"\\r\\n         #rlaPublishers=\\\"routerLinkActive\\\"\\r\\n         [attr.aria-current]=\\\"rlaPublishers.isActive ? 'page' : null\\\">\\r\\n        <mat-icon>business</mat-icon>\\r\\n        <span>Publishers</span>\\r\\n      </a>\\r\\n    </mat-menu>\\r\\n  </mat-card-header>\\r\\n\\r\\n  <mat-card-content>\\r\\n    <router-outlet></router-outlet>\\r\\n  </mat-card-content>\\r\\n</mat-card>\\r\\n\",\"import { Routes } from '@angular/router';\\r\\nimport { CatalogShell } from '../shell/catalog-shell';\\r\\n\\r\\nexport const CATALOG_ROUTES: Routes = [\\r\\n  {\\r\\n    path: '',\\r\\n    component: CatalogShell,\\r\\n    children: [\\r\\n      { path: '', redirectTo: 'literary-genres', pathMatch: 'full' },\\r\\n      { path: 'literary-genres', loadComponent: () => import('../pages/literary-genre-list-page/literary-genre-list-page').then(m => m.LiteraryGenreListPage) },\\r\\n      { path: 'publishers',      loadComponent: () => import('../pages/publisher-list-page/publisher-list-page').then(m => m.PublisherListPage) },\\r\\n    ],\\r\\n  },\\r\\n];\\r\\n\",\"import { InjectionToken } from '@angular/core';\\r\\nimport type { LiteraryGenrePublicApi } from './literary-genre.public-api';\\r\\nimport type { PublisherPublicApi } from './publisher.public-api';\\r\\n\\r\\n/**\\r\\n * Combined Catalog module Public API (Facade).\\r\\n */\\r\\n// eslint-disable-next-line @typescript-eslint/no-empty-object-type\\r\\nexport interface CatalogPublicApi extends LiteraryGenrePublicApi, PublisherPublicApi {}\\r\\n\\r\\nexport const CATALOG_PUBLIC_API = new InjectionToken<CatalogPublicApi>('CatalogPublicApi');\\r\\n\",\"import { InjectionToken } from '@angular/core';\\r\\nimport type { PagedList, IQueryService, Specification, SortField } from '@eac-arch/shared-kernel';\\r\\nimport type { LiteraryGenreModel } from '../../../models';\\r\\n\\r\\nexport interface LiteraryGenreQueryService extends IQueryService<LiteraryGenreModel> {\\r\\n  getAllLiteraryGenres(\\r\\n    pageNumber: number,\\r\\n    pageSize: number,\\r\\n    spec?: Specification<LiteraryGenreModel>,\\r\\n    sortFields?: SortField[],\\r\\n    fields?: string[],\\r\\n  ): Promise<PagedList<LiteraryGenreModel>>;\\r\\n\\r\\n  getLiteraryGenreById(literaryGenreId: string, fields?: string[]): Promise<LiteraryGenreModel | null>;\\r\\n\\r\\n  existsLiteraryGenre(literaryGenreId: string): Promise<boolean>;\\r\\n\\r\\n  checkLiteraryGenreNameUniqueness(name: string, excludeLiteraryGenreId?: string): Promise<boolean>;\\r\\n}\\r\\n\\r\\nexport const LITERARY_GENRE_QUERY_SERVICE = new InjectionToken<LiteraryGenreQueryService>('LiteraryGenreQueryService');\\r\\n\",\"import { InjectionToken } from '@angular/core';\\r\\nimport type { PagedList, IQueryService, Specification, SortField } from '@eac-arch/shared-kernel';\\r\\nimport type { PublisherModel } from '../../../models';\\r\\n\\r\\nexport interface PublisherQueryService extends IQueryService<PublisherModel> {\\r\\n  getAllPublishers(\\r\\n    pageNumber: number,\\r\\n    pageSize: number,\\r\\n    spec?: Specification<PublisherModel>,\\r\\n    sortFields?: SortField[],\\r\\n    fields?: string[],\\r\\n  ): Promise<PagedList<PublisherModel>>;\\r\\n\\r\\n  getPublisherById(publisherId: string, fields?: string[]): Promise<PublisherModel | null>;\\r\\n\\r\\n  existsPublisher(publisherId: string): Promise<boolean>;\\r\\n\\r\\n  checkPublisherNameUniqueness(name: string, excludePublisherId?: string): Promise<boolean>;\\r\\n}\\r\\n\\r\\nexport const PUBLISHER_QUERY_SERVICE = new InjectionToken<PublisherQueryService>('PublisherQueryService');\\r\\n\",\"import { QuerySpecification } from '@eac-arch/shared-kernel';\\r\\nimport type { LiteraryGenreModel } from '../../application/models';\\r\\n\\r\\nexport class LiteraryGenreSearchSpec extends QuerySpecification<LiteraryGenreModel> {\\r\\n  constructor(private readonly term?: string) {\\r\\n    super();\\r\\n  }\\r\\n\\r\\n  isSatisfiedBy(candidate: LiteraryGenreModel): boolean {\\r\\n    if (!this.term?.trim()) return true;\\r\\n    const search = this.term.trim().toLowerCase();\\r\\n\\r\\n    return (\\r\\n      candidate.name.toLowerCase().includes(search) ||\\r\\n      (candidate.description?.toLowerCase().includes(search) ?? false)\\r\\n    );\\r\\n  }\\r\\n\\r\\n  toQueryParams(): Record<string, string> {\\r\\n    const params: Record<string, string> = {};\\r\\n    if (this.term?.trim()) params['search'] = this.term.trim();\\r\\n    return params;\\r\\n  }\\r\\n}\\r\\n\",\"import { QuerySpecification } from '@eac-arch/shared-kernel';\\r\\nimport type { PublisherModel } from '../../application/models';\\r\\n\\r\\nexport class PublisherSearchSpec extends QuerySpecification<PublisherModel> {\\r\\n  constructor(private readonly term?: string) {\\r\\n    super();\\r\\n  }\\r\\n\\r\\n  isSatisfiedBy(candidate: PublisherModel): boolean {\\r\\n    if (!this.term?.trim()) return true;\\r\\n    const search = this.term.trim().toLowerCase();\\r\\n\\r\\n    return (\\r\\n      candidate.name.toLowerCase().includes(search) ||\\r\\n      (candidate.country?.toLowerCase().includes(search) ?? false) ||\\r\\n      (candidate.website?.toLowerCase().includes(search) ?? false)\\r\\n    );\\r\\n  }\\r\\n\\r\\n  toQueryParams(): Record<string, string> {\\r\\n    const params: Record<string, string> = {};\\r\\n    if (this.term?.trim()) params['search'] = this.term.trim();\\r\\n    return params;\\r\\n  }\\r\\n}\\r\\n\",\"// LiteraryGenre specifications\\r\\nexport { LiteraryGenreSearchSpec } from './literary-genre-search.spec';\\r\\n\\r\\n// Publisher specifications\\r\\nexport { PublisherSearchSpec } from './publisher-search.spec';\\r\\n\",\"import { inject, Injectable } from '@angular/core';\\r\\nimport type { QueryUseCase } from '@eac-arch/shared-kernel';\\r\\nimport { QuerySpecificationBuilder } from '@eac-arch/shared-kernel';\\r\\